# ============================================================
# RX Skin — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to Git.
# ============================================================

# ── ConnectWise Manage ──────────────────────────────────────
# Your CW server base URL (no trailing slash)
CW_BASE_URL=https://na.myconnectwise.net/v4_6_release/apis/3.0

# Company short name (lowercase, used in Basic Auth)
CW_COMPANY_ID=yourcompany

# Register at developer.connectwise.com to get a Client ID
CW_CLIENT_ID=

# API Member public + private keys (from System → Members → API member)
CW_PUBLIC_KEY=
CW_PRIVATE_KEY=

# ── Database ────────────────────────────────────────────────
# PostgreSQL connection string (Supabase: Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ── Authentication ──────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Your app's base URL
NEXTAUTH_URL=http://localhost:3001

# ── Microsoft Graph (Phase 2) ───────────────────────────────
# Azure App Registration credentials (per-tenant, stored in DB for multi-tenant)
# These are your DEFAULT / internal tenant credentials
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ── Encryption ──────────────────────────────────────────────
# 32-character key for encrypting API credentials at rest
# Generate with: openssl rand -hex 16
ENCRYPTION_KEY=

# ── Samsara Fleet ─────────────────────────────────────────
SAMSARA_API_TOKEN=
SAMSARA_BASE_URL=https://api.samsara.com

# ── Phase 1 Login ─────────────────────────────────────────
# Admin credentials for Phase 1 (will be replaced by Azure AD SSO in Phase 2)
ADMIN_EMAIL=admin@rxtechnology.com
ADMIN_PASSWORD=

# Tenant + member defaults
TENANT_ID=rx-technology
CW_MEMBER_ID=TBrown
DEPARTMENT=SI

# ── SmileBack (CSAT/NPS) ──────────────────────────────────
SMILEBACK_WEBHOOK_SECRET=

# ── App Config ──────────────────────────────────────────────
NODE_ENV=development
